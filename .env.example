# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it contains secrets.

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# From your service account JSON file ("client_email" field)
GOOGLE_SERVICE_ACCOUNT_EMAIL=uplift-sheets@your-project.iam.gserviceaccount.com

# From your service account JSON file ("private_key" field)
# Paste the entire key including -----BEGIN... and -----END...
# In Vercel's dashboard, paste it exactly as-is (with real newlines).
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
